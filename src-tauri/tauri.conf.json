{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sanctuary Player",
  "version": "0.1.0",
  "identifier": "com.moses2917.sanctuary-player",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sanctuary Player",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' sanctuary-media: http://sanctuary-media.localhost",
        "img-src": "'self' data: blob:",
        "media-src": "'self' blob: sanctuary-media: http://sanctuary-media.localhost",
        "style-src": "'self' 'unsafe-inline'",
        "worker-src": "'self' blob:"
      },
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    },
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
